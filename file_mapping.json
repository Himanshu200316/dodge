  "type_casting_rules": {
    "netAmount": "toFloat()",
    "totalNetAmount": "toFloat()",
    "billingQuantity": "toInteger()",
    "requestedQuantity": "toInteger()",
    "grossWeight": "toFloat()",
    "netWeight": "toFloat()",
    "creationDate": "date(substring(value, 0, 10))",
    "billingDocumentDate": "date(substring(value, 0, 10))",
    "actualGoodsMovementDate": "date(substring(value, 0, 10))"
  }
}
